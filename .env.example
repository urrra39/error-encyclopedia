# =============================================================================
# Error Encyclopedia — docker-compose configuration
#
# Copy to `.env` and adjust as needed. Every value has a safe default baked
# into docker-compose.yml, so `docker compose up --build` works without this
# file — but you SHOULD set real secrets before any non-local deployment.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=error_enc
POSTGRES_PASSWORD=error_enc_secret
POSTGRES_DB=error_encyclopedia
POSTGRES_PORT=5432

# --- Meilisearch ---
# Must be at least 16 bytes when MEILI_ENV=production. Change this for real use.
MEILI_MASTER_KEY=aSampleMasterKeyChangeMeInProd123
MEILI_ENV=production
MEILISEARCH_PORT=7700

# --- Service ports (host side) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend → backend URL (browser-reachable; baked into the client bundle) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
