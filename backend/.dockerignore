# Keep the build context small and free of secrets / local cruft.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local environment / secrets — never bake these into an image.
.env
.env.*
!.env.example

# Tooling
.git/
.gitignore
*.md
Dockerfile
.dockerignore
